# ejercico 8 
temps = []
for i in range(30):
    temps.append(float(input(f"Día {i+1}: ")))

prom = sum(temps) / 30
arriba = len([t for t in temps if t > prom])
abajo = len([t for t in temps if t < prom])

print(f"Promedio: {prom:.1f} | Max: {max(temps)} | Min: {min(temps)}")
print(f"Días sobre el promedio: {arriba} | Días bajo: {abajo}")
