# ejercicio 2 
import math

n = int(input("Cantidad de datos a ingresar: "))
datos = []
for i in range(n):
    valor = float(input(f"Ingrese el dato {i+1}: "))
    datos.append(valor)

promedio = sum(datos) / n
suma_cuadrados = sum((x - promedio)**2 for x in datos)
desviacion = math.sqrt(suma_cuadrados / n)

print(f"La desviación típica es: {desviacion:.2f}")
