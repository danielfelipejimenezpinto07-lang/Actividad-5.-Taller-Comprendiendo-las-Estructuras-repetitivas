# Ejercicio 5
n = int(input("¿Cuántas ternas desea evaluar?: "))
contador = 0
for i in range(n):
    print(f"Terna {i+1}:")
    lados = sorted([float(input("Lado 1: ")), float(input("Lado 2: ")), float(input("Lado 3: "))])
    # Teorema de Pitágoras: a^2 + b^2 = c^2 (c es el más largo)
    if lados[0]**2 + lados[1]**2 == lados[2]**2:
        contador += 1
print(f"Total de triángulos rectángulos: {contador}")
