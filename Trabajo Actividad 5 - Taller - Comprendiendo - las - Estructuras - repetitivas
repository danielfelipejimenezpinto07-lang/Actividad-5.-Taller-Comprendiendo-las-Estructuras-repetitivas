# ejercico 9
num = int(input("Número decimal: "))
base = int(input("Base destino (2-16): "))
digitos = "0123456789ABCDEF"
res = ""

while num > 0:
    res = digitos[num % base] + res
    num //= base

print(f"Resultado: {res}")
